Options -Indexes -MultiViews

RewriteEngine On

# Clean URLs for project pages (/projects/foo -> projects/foo.php)
RewriteRule ^projects/([a-zA-Z0-9_-]+)$ projects/$1.php [L]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Redirect everything else to 404.php
RewriteRule ^ 404.php [L]

# Custom error document
ErrorDocument 404 /Marcus-Loo/404.php
